{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "record_type": {
            "const": "evidence"
          }
        }
      },
      "then": {
        "required": [
          "descriptors"
        ]
      }
    }
  ],
  "properties": {
    "acquisition_source": {
      "properties": {
        "computation": {
          "type": "object"
        },
        "facility": {
          "type": "object"
        },
        "laboratory": {
          "type": "object"
        },
        "literature": {
          "type": "object"
        },
        "source_type": {
          "enum": [
            "facility",
            "laboratory",
            "computation",
            "literature",
            "database"
          ],
          "type": "string"
        }
      },
      "required": [
        "source_type"
      ],
      "type": "object"
    },
    "assets": {
      "items": {
        "properties": {
          "asset_id": {
            "type": "string"
          },
          "content_role": {
            "enum": [
              "raw_data_pointer",
              "reduction_product",
              "processing_recipe",
              "input_structure",
              "metadata_snapshot",
              "supplementary_image",
              "other"
            ],
            "type": "string"
          },
          "media_type": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          },
          "uri": {
            "type": "string"
          }
        },
        "required": [
          "asset_id",
          "content_role",
          "uri",
          "sha256"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "computation": {
      "type": "object"
    },
    "context": {
      "additionalProperties": true,
      "properties": {
        "environment": {
          "enum": [
            "operando",
            "in_situ",
            "ex_situ",
            "in_silico"
          ],
          "type": "string"
        },
        "temperature_K": {
          "type": "number"
        }
      },
      "required": [
        "environment",
        "temperature_K"
      ],
      "type": "object"
    },
    "descriptors": {
      "properties": {
        "outputs": {
          "items": {
            "properties": {
              "descriptors": {
                "items": {
                  "properties": {
                    "kind": {
                      "enum": [
                        "absolute",
                        "differential",
                        "categorical",
                        "similarity",
                        "model"
                      ],
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "source": {
                      "type": "string"
                    },
                    "uncertainty": {
                      "type": "object"
                    },
                    "unit": {
                      "type": "string"
                    },
                    "value": {}
                  },
                  "required": [
                    "name",
                    "kind",
                    "source",
                    "value",
                    "uncertainty"
                  ],
                  "type": "object"
                },
                "type": "array"
              },
              "generated_by": {
                "type": "object"
              },
              "generated_utc": {
                "type": "string"
              },
              "label": {
                "type": "string"
              }
            },
            "required": [
              "label",
              "generated_utc",
              "generated_by",
              "descriptors"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "policy": {
          "type": "object"
        }
      },
      "required": [
        "outputs"
      ],
      "type": "object"
    },
    "device": {
      "type": "object"
    },
    "isaac_record_version": {
      "const": "1.0",
      "type": "string"
    },
    "links": {
      "items": {
        "properties": {
          "basis": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "rel": {
            "enum": [
              "derived_from",
              "intended_comparison_target",
              "calibration_of",
              "same_sample_as",
              "replica_of",
              "follows",
              "validates",
              "invalidates"
            ],
            "type": "string"
          },
          "target": {
            "pattern": "^[0-9A-Z]{26}$",
            "type": "string"
          }
        },
        "required": [
          "rel",
          "target"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "literature": {
      "type": "object"
    },
    "measurement": {
      "properties": {
        "processing": {
          "type": "object"
        },
        "qc": {
          "required": [
            "status"
          ],
          "type": "object"
        },
        "series": {
          "items": {
            "properties": {
              "channels": {
                "items": {
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "role": {
                      "enum": [
                        "primary_signal",
                        "measured_response",
                        "simulated_observable",
                        "derived_signal",
                        "auxiliary_signal",
                        "control_readback",
                        "quality_monitor"
                      ],
                      "type": "string"
                    },
                    "unit": {
                      "type": "string"
                    },
                    "values": {
                      "items": {
                        "type": "number"
                      },
                      "type": "array"
                    }
                  },
                  "required": [
                    "name",
                    "unit",
                    "role"
                  ],
                  "type": "object"
                },
                "type": "array"
              },
              "independent_variables": {
                "items": {
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "unit": {
                      "type": "string"
                    },
                    "values": {
                      "items": {
                        "type": "number"
                      },
                      "type": "array"
                    }
                  },
                  "required": [
                    "name",
                    "unit"
                  ],
                  "type": "object"
                },
                "type": "array"
              },
              "series_id": {
                "type": "string"
              }
            },
            "required": [
              "series_id",
              "independent_variables",
              "channels"
            ],
            "type": "object"
          },
          "type": "array"
        }
      },
      "required": [
        "series",
        "qc"
      ],
      "type": "object"
    },
    "record_domain": {
      "description": "Scientific domain of the record content.",
      "enum": [
        "characterization",
        "performance",
        "simulation",
        "theory",
        "derived"
      ],
      "type": "string"
    },
    "record_id": {
      "description": "ULID identifier for the record.",
      "pattern": "^[0-9A-Z]{26}$",
      "type": "string"
    },
    "record_type": {
      "description": "Fundamental nature of the record.",
      "enum": [
        "evidence",
        "intent",
        "synthesis"
      ],
      "type": "string"
    },
    "sample": {
      "properties": {
        "composition": {
          "type": "object"
        },
        "geometry": {
          "type": "object"
        },
        "material": {
          "properties": {
            "formula": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "provenance": {
              "enum": [
                "commercial",
                "synthesized",
                "theoretical",
                "literature",
                "natural"
              ],
              "type": "string"
            }
          },
          "required": [
            "name",
            "formula"
          ],
          "type": "object"
        },
        "sample_form": {
          "enum": [
            "powder",
            "pellet",
            "film",
            "monolith",
            "liquid",
            "gas",
            "single_crystal",
            "slab_model",
            "cluster_model",
            "unit_cell",
            "fluids"
          ],
          "type": "string"
        }
      },
      "required": [
        "material",
        "sample_form"
      ],
      "type": "object"
    },
    "system": {
      "properties": {
        "configuration": {
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "boolean"
            ]
          },
          "description": "Flat object of categorical settings. No nested objects allowed.",
          "type": "object"
        },
        "domain": {
          "enum": [
            "experimental",
            "computational",
            "empirical"
          ],
          "type": "string"
        },
        "facility": {
          "type": "object"
        },
        "instrument": {
          "type": "object"
        },
        "simulation": {
          "properties": {
            "method": {
              "enum": [
                "DFT",
                "ab_initio_MD",
                "classical_MD",
                "kinetic_monte_carlo",
                "microkinetic_modeling",
                "machine_learning_potential"
              ],
              "type": "string"
            }
          },
          "required": [
            "method"
          ],
          "type": "object"
        }
      },
      "required": [
        "domain",
        "configuration"
      ],
      "type": "object"
    },
    "timestamps": {
      "properties": {
        "acquired_end_utc": {
          "format": "date-time",
          "type": "string"
        },
        "acquired_start_utc": {
          "format": "date-time",
          "type": "string"
        },
        "created_utc": {
          "format": "date-time",
          "type": "string"
        }
      },
      "required": [
        "created_utc"
      ],
      "type": "object"
    }
  },
  "required": [
    "isaac_record_version",
    "record_id",
    "record_type",
    "record_domain",
    "timestamps",
    "acquisition_source"
  ],
  "title": "ISAAC AI-Ready Scientific Record v1.0",
  "type": "object"
}
