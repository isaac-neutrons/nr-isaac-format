{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "record_type": {
            "const": "evidence"
          }
        }
      },
      "then": {
        "required": [
          "descriptors"
        ]
      }
    }
  ],
  "properties": {
    "assets": {
      "items": {
        "properties": {
          "asset_id": {
            "type": "string"
          },
          "content_role": {
            "enum": [
              "raw_data",
              "raw_data_pointer",
              "reduction_product",
              "input_structure",
              "workflow_recipe",
              "processing_script",
              "calibration_reference",
              "auxiliary_reference",
              "documentation",
              "metadata_snapshot",
              "supplementary_image",
              "other"
            ],
            "type": "string"
          },
          "media_type": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          },
          "uri": {
            "type": "string"
          }
        },
        "required": [
          "asset_id",
          "content_role",
          "uri",
          "sha256"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "computation": {
      "properties": {
        "method": {
          "description": "Declared theory level: method family, functional, code details.",
          "properties": {
            "basis_type": {
              "description": "Basis set type.",
              "enum": [
                "planewave",
                "LCAO",
                "real_space",
                "mixed"
              ],
              "type": "string"
            },
            "convergence": {
              "properties": {
                "energy_eV": {
                  "type": "number"
                },
                "force_eV_per_A": {
                  "type": "number"
                },
                "stress_kbar": {
                  "type": "number"
                }
              },
              "type": "object"
            },
            "cutoff_eV": {
              "description": "Planewave kinetic energy cutoff in eV.",
              "type": "number"
            },
            "dispersion": {
              "description": "Dispersion correction method.",
              "enum": [
                "none",
                "D2",
                "D3",
                "D3BJ",
                "TS",
                "MBD",
                "dDsC",
                "vdW_DF",
                "vdW_DF2",
                "rVV10"
              ],
              "type": "string"
            },
            "family": {
              "description": "Method family.",
              "enum": [
                "DFT",
                "DFT_U",
                "hybrid_DFT",
                "AIMD",
                "classical_MD",
                "CHE",
                "microkinetic",
                "machine_learning",
                "semi_empirical"
              ],
              "type": "string"
            },
            "functional_class": {
              "description": "Density functional class.",
              "enum": [
                "LDA",
                "GGA",
                "meta_GGA",
                "hybrid",
                "double_hybrid",
                "RPA"
              ],
              "type": "string"
            },
            "functional_name": {
              "description": "Specific functional (e.g., PBE, RPBE, BEEF-vdW, HSE06).",
              "type": "string"
            },
            "kpoints": {
              "description": "Brillouin zone sampling (e.g., '3x3x1 Monkhorst-Pack', 'Gamma-only').",
              "type": "string"
            },
            "pseudopotential": {
              "description": "Pseudopotential type (e.g., PAW, ultrasoft, norm_conserving, GBRV, SG15).",
              "type": "string"
            },
            "relativistic": {
              "description": "Relativistic treatment.",
              "enum": [
                "none",
                "scalar",
                "full"
              ],
              "type": "string"
            },
            "smearing": {
              "properties": {
                "method": {
                  "description": "Electronic smearing method.",
                  "enum": [
                    "Gaussian",
                    "Methfessel-Paxton",
                    "Fermi-Dirac",
                    "tetrahedron",
                    "cold"
                  ],
                  "type": "string"
                },
                "width_eV": {
                  "type": "number"
                }
              },
              "type": "object"
            },
            "spin_treatment": {
              "description": "Spin polarization treatment.",
              "enum": [
                "none",
                "collinear",
                "noncollinear",
                "SOC"
              ],
              "type": "string"
            }
          },
          "type": "object"
        },
        "output_quantity": {
          "description": "Specifies what quantity is computed and which corrections are applied. CRITICAL for valid comparison between records.",
          "properties": {
            "corrections_applied": {
              "description": "Boolean flags for each correction included in the reported quantity.",
              "properties": {
                "PCET": {
                  "type": "boolean"
                },
                "dispersion": {
                  "type": "boolean"
                },
                "entropy": {
                  "type": "boolean"
                },
                "grand_canonical": {
                  "type": "boolean"
                },
                "solvation": {
                  "type": "boolean"
                },
                "thermal": {
                  "type": "boolean"
                },
                "zero_point_energy": {
                  "type": "boolean"
                }
              },
              "type": "object"
            },
            "quantity": {
              "description": "The thermodynamic quantity reported in descriptors.",
              "enum": [
                "E_DFT",
                "E_DFT_plus_ZPE",
                "delta_E",
                "delta_G_CHE",
                "delta_G_grand_canonical",
                "activation_energy_raw",
                "activation_energy_ZPE",
                "activation_free_energy"
              ],
              "type": "string"
            }
          },
          "type": "object"
        },
        "potential_method": {
          "description": "How the electrochemical potential is treated in the simulation.",
          "properties": {
            "SHE_work_function_eV": {
              "description": "Assumed SHE work function (typically 4.4-4.8 eV).",
              "type": "number"
            },
            "dielectric_constant": {
              "type": "number"
            },
            "solvent_model": {
              "description": "Implicit solvent implementation (e.g., VASPsol, GLSSA13, CANDLE).",
              "type": "string"
            },
            "target_potential_V_SHE": {
              "type": "number"
            },
            "type": {
              "description": "Electrochemical potential treatment.",
              "enum": [
                "vacuum",
                "CHE",
                "implicit_solvent_PZC",
                "fixed_NELECT",
                "grand_canonical",
                "constant_potential",
                "joint_DFT"
              ],
              "type": "string"
            }
          },
          "type": "object"
        },
        "slab_model": {
          "description": "Surface slab model parameters. Only relevant when sample.sample_form = 'slab_model'.",
          "properties": {
            "dipole_correction": {
              "type": "boolean"
            },
            "fixed_layers": {
              "description": "e.g., 'bottom 2'",
              "type": "string"
            },
            "lattice_constant_A": {
              "type": "number"
            },
            "layers": {
              "type": "integer"
            },
            "supercell": {
              "description": "e.g., '4x4', '4x3', '3x3'",
              "type": "string"
            },
            "surface_facet": {
              "description": "e.g., '111', '100', '110', '211'",
              "type": "string"
            },
            "vacuum_A": {
              "type": "number"
            }
          },
          "type": "object"
        },
        "transition_state": {
          "description": "Transition state search parameters. Only for barrier calculations.",
          "properties": {
            "images": {
              "description": "Number of NEB images.",
              "type": "integer"
            },
            "method": {
              "description": "TS search method.",
              "enum": [
                "NEB",
                "CI-NEB",
                "dimer",
                "string",
                "IRC",
                "growing_string"
              ],
              "type": "string"
            },
            "n_electrons_transferred": {
              "description": "Electrons transferred in this step (0 for chemical, 1 for PCET).",
              "type": "integer"
            },
            "reaction": {
              "description": "e.g., 'CO* + CO* \u2192 OCCO*'",
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "context": {
      "additionalProperties": false,
      "properties": {
        "electrochemistry": {
          "properties": {
            "cell_type": {
              "enum": [
                "flow_cell",
                "microfluidic_flow_cell",
                "h_cell",
                "beaker_cell",
                "gde_cell",
                "mea_cell",
                "zero_gap_cell",
                "coin_cell",
                "three_electrode"
              ],
              "type": "string"
            },
            "control_mode": {
              "enum": [
                "potentiostatic",
                "galvanostatic",
                "potentiodynamic",
                "open_circuit",
                "mixed"
              ],
              "type": "string"
            },
            "current_setpoint_mA_cm2": {
              "type": "number"
            },
            "electrolyte": {
              "properties": {
                "concentration_M": {
                  "type": "number"
                },
                "name": {
                  "type": "string"
                }
              },
              "required": [
                "name",
                "concentration_M"
              ],
              "type": "object"
            },
            "ir_compensation": {
              "properties": {
                "method": {
                  "enum": [
                    "none",
                    "automatic",
                    "manual",
                    "post_hoc",
                    "EIS_based"
                  ],
                  "type": "string"
                },
                "percent": {
                  "type": "number"
                }
              },
              "type": "object"
            },
            "pH": {
              "type": "number"
            },
            "pH_basis": {
              "enum": [
                "measured",
                "nominal",
                "buffered_assumed"
              ],
              "type": "string"
            },
            "potential_scale": {
              "enum": [
                "RHE",
                "SHE",
                "Ag/AgCl",
                "SCE",
                "Hg/HgO",
                "Hg/HgSO4",
                "V_vs_Ref"
              ],
              "type": "string"
            },
            "potential_setpoint_V": {
              "type": "number"
            },
            "reaction": {
              "enum": [
                "CO2RR",
                "CORR",
                "OER",
                "HER",
                "ORR",
                "NRR",
                "N2RR",
                "AOR",
                "FOR",
                "water_splitting",
                "surface_oxidation",
                "stripping_voltammetry",
                "None"
              ],
              "type": "string"
            },
            "scan_rate_mV_s": {
              "type": "number"
            }
          },
          "type": "object"
        },
        "environment": {
          "enum": [
            "operando",
            "in_situ",
            "ex_situ",
            "in_silico"
          ],
          "type": "string"
        },
        "simulation_assumptions": {
          "properties": {
            "solvation_model": {
              "enum": [
                "none",
                "implicit",
                "explicit"
              ],
              "type": "string"
            }
          },
          "type": "object"
        },
        "temperature_K": {
          "type": "number"
        },
        "thermodynamics": {
          "properties": {
            "atmosphere": {
              "type": "string"
            },
            "pressure_Pa": {
              "type": "number"
            }
          },
          "type": "object"
        },
        "transport": {
          "properties": {
            "feed": {
              "description": "Feed must be an object with phase and composition. Do not use a bare string.",
              "properties": {
                "composition": {
                  "type": "string"
                },
                "flow_rate": {
                  "type": "number"
                },
                "flow_rate_unit": {
                  "type": "string"
                },
                "partial_pressures": {
                  "type": "object"
                },
                "phase": {
                  "enum": [
                    "gas",
                    "liquid"
                  ],
                  "type": "string"
                }
              },
              "required": [
                "phase",
                "composition"
              ],
              "type": "object"
            },
            "flow_mode": {
              "enum": [
                "stagnant",
                "flowing_liquid",
                "bubbling_gas",
                "gas_diffusion",
                "rotating_disk"
              ],
              "type": "string"
            },
            "rotation_speed_rpm": {
              "type": "number"
            }
          },
          "type": "object"
        }
      },
      "required": [
        "environment",
        "temperature_K"
      ],
      "type": "object"
    },
    "descriptors": {
      "properties": {
        "outputs": {
          "items": {
            "properties": {
              "descriptors": {
                "items": {
                  "properties": {
                    "kind": {
                      "enum": [
                        "absolute",
                        "differential",
                        "categorical",
                        "similarity",
                        "model",
                        "theoretical_metric"
                      ],
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "source": {
                      "enum": [
                        "auto",
                        "manual",
                        "imported"
                      ],
                      "type": "string"
                    },
                    "uncertainty": {
                      "type": "object"
                    },
                    "unit": {
                      "type": "string"
                    },
                    "value": {
                      "description": "The asserted value. Must not be null \u2014 a descriptor without a value is not a scientific claim.",
                      "not": {
                        "type": "null"
                      }
                    }
                  },
                  "required": [
                    "name",
                    "kind",
                    "source",
                    "value",
                    "uncertainty"
                  ],
                  "type": "object"
                },
                "type": "array"
              },
              "generated_by": {
                "type": "object"
              },
              "generated_utc": {
                "description": "ISO 8601 timestamp of when the descriptors were generated. Placeholder strings are not allowed.",
                "format": "date-time",
                "type": "string"
              },
              "label": {
                "type": "string"
              }
            },
            "required": [
              "label",
              "generated_utc",
              "generated_by",
              "descriptors"
            ],
            "type": "object"
          },
          "type": "array"
        }
      },
      "required": [
        "outputs"
      ],
      "type": "object"
    },
    "isaac_record_version": {
      "const": "1.05",
      "type": "string"
    },
    "links": {
      "items": {
        "properties": {
          "basis": {
            "enum": [
              "same_absorber_edge",
              "matched_operating_conditions",
              "shared_reference_state",
              "same_workflow_version",
              "identical_geometry",
              "analysis_pipeline_output",
              "replicate_preparation",
              "same_sample_id",
              "shared_analysis_method",
              "shared_material_batch",
              "matched_computational_method",
              "unspecified"
            ],
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "rel": {
            "enum": [
              "derived_from",
              "intended_comparison_target",
              "calibration_of",
              "same_sample_as",
              "replica_of",
              "follows",
              "validates",
              "invalidates"
            ],
            "type": "string"
          },
          "target": {
            "pattern": "^[0-9A-Z]{26}$",
            "type": "string"
          }
        },
        "required": [
          "rel",
          "target",
          "basis"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "literature": {
      "type": "object"
    },
    "measurement": {
      "properties": {
        "processing": {
          "type": "object"
        },
        "qc": {
          "required": [
            "status"
          ],
          "type": "object"
        },
        "series": {
          "items": {
            "properties": {
              "channels": {
                "items": {
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "role": {
                      "enum": [
                        "primary_signal",
                        "measured_response",
                        "simulated_observable",
                        "derived_signal",
                        "auxiliary_signal",
                        "control_readback",
                        "quality_monitor"
                      ],
                      "type": "string"
                    },
                    "unit": {
                      "type": "string"
                    },
                    "values": {
                      "items": {
                        "type": "number"
                      },
                      "type": "array"
                    }
                  },
                  "required": [
                    "name",
                    "unit",
                    "role"
                  ],
                  "type": "object"
                },
                "type": "array"
              },
              "independent_variables": {
                "items": {
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "unit": {
                      "type": "string"
                    },
                    "values": {
                      "items": {
                        "type": "number"
                      },
                      "type": "array"
                    }
                  },
                  "required": [
                    "name",
                    "unit"
                  ],
                  "type": "object"
                },
                "type": "array"
              },
              "series_id": {
                "type": "string"
              }
            },
            "required": [
              "series_id",
              "independent_variables",
              "channels"
            ],
            "type": "object"
          },
          "type": "array"
        }
      },
      "required": [
        "series",
        "qc"
      ],
      "type": "object"
    },
    "record_domain": {
      "description": "Scientific domain of the record content.",
      "enum": [
        "characterization",
        "performance",
        "simulation",
        "theory",
        "derived"
      ],
      "type": "string"
    },
    "record_id": {
      "description": "ULID identifier for the record.",
      "pattern": "^[0-9A-Z]{26}$",
      "type": "string"
    },
    "record_type": {
      "description": "Fundamental nature of the record.",
      "enum": [
        "evidence",
        "intent",
        "synthesis"
      ],
      "type": "string"
    },
    "sample": {
      "properties": {
        "composition": {
          "enum": [
            "catalyst_loading_mg_cm2",
            "Cu_pct",
            "Au_pct",
            "Ag_pct",
            "Pt_pct"
          ],
          "type": "object"
        },
        "electrode_type": {
          "description": "Type of electrode or substrate configuration (e.g., GDE, RDE, RRDE, foil, MEA).",
          "enum": [
            "GDE",
            "thin_film",
            "patterned_film",
            "nanoparticle",
            "foil",
            "mesh",
            "RDE",
            "RRDE",
            "pellet",
            "single_crystal",
            "MEA",
            "flow_field_plate"
          ],
          "type": "string"
        },
        "geometry": {
          "enum": [
            "geometric_area_cm2",
            "thickness_um",
            "particle_size_nominal_nm",
            "loading_mg_cm2"
          ],
          "type": "object"
        },
        "material": {
          "properties": {
            "formula": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "provenance": {
              "enum": [
                "commercial",
                "synthesized",
                "fabricated",
                "theoretical",
                "literature",
                "natural"
              ],
              "type": "string"
            }
          },
          "required": [
            "name",
            "formula"
          ],
          "type": "object"
        },
        "sample_form": {
          "enum": [
            "powder",
            "pellet",
            "film",
            "monolith",
            "liquid",
            "gas",
            "single_crystal",
            "nanoparticle",
            "membrane_electrode_assembly",
            "slab_model",
            "cluster_model",
            "unit_cell",
            "fluids"
          ],
          "type": "string"
        }
      },
      "required": [
        "material",
        "sample_form"
      ],
      "type": "object"
    },
    "source_type": {
      "description": "Origin of the data acquisition.",
      "enum": [
        "facility",
        "laboratory",
        "computation",
        "literature",
        "database",
        "industrial"
      ],
      "type": "string"
    },
    "system": {
      "properties": {
        "configuration": {
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "boolean"
            ]
          },
          "description": "Flat object of categorical settings. No nested objects allowed.",
          "enum": [
            "detector_model",
            "monochromator_crystal",
            "spectrometer_geometry",
            "compute_architecture",
            "code_version",
            "container_image",
            "channel_id",
            "electrode_configuration",
            "reference_electrode",
            "counter_electrode",
            "membrane",
            "gc_column_type",
            "gc_model",
            "cell_geometry",
            "anolyte",
            "product_detection_gas",
            "product_detection_liquid",
            "scan_rate_mV_s",
            "beam_attenuator"
          ],
          "type": "object"
        },
        "domain": {
          "enum": [
            "experimental",
            "computational"
          ],
          "type": "string"
        },
        "facility": {
          "type": "object"
        },
        "instrument": {
          "type": "object"
        },
        "technique": {
          "description": "Primary technique or computational method used to produce this record.",
          "enum": [
            "XAS",
            "HERFD-XAS",
            "XES",
            "RIXS",
            "XPS",
            "XRF",
            "XRD",
            "SAXS",
            "WAXS",
            "PDF",
            "neutron_reflectometry",
            "neutron_diffraction",
            "SANS",
            "cyclic_voltammetry",
            "chronoamperometry",
            "chronopotentiometry",
            "EIS",
            "linear_sweep_voltammetry",
            "TEM",
            "SEM",
            "AFM",
            "STM",
            "DFT",
            "ab_initio_MD",
            "classical_MD",
            "kinetic_monte_carlo",
            "microkinetic_modeling",
            "machine_learning_potential",
            "GC",
            "HPLC",
            "ICP_MS",
            "ICP_OES",
            "NMR",
            "mass_spectrometry",
            "FTIR",
            "Raman",
            "UV_Vis"
          ],
          "type": "string"
        }
      },
      "required": [
        "domain",
        "technique"
      ],
      "type": "object"
    },
    "timestamps": {
      "properties": {
        "acquired_end_utc": {
          "format": "date-time",
          "type": "string"
        },
        "acquired_start_utc": {
          "format": "date-time",
          "type": "string"
        },
        "created_utc": {
          "format": "date-time",
          "type": "string"
        }
      },
      "required": [
        "created_utc"
      ],
      "type": "object"
    }
  },
  "required": [
    "isaac_record_version",
    "record_id",
    "record_type",
    "record_domain",
    "source_type",
    "timestamps"
  ],
  "title": "ISAAC AI-Ready Scientific Record v1.05",
  "type": "object"
}
